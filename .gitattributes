# Normaliza archivos de texto.
# En el repositorio se guardan como LF.
* text=auto

# Código fuente y archivos de configuración: siempre LF.
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf
*.py     text eol=lf
*.go     text eol=lf
*.rs     text eol=lf
*.java   text eol=lf
*.sql    text eol=lf

# Archivos propios de Windows que normalmente requieren CRLF.
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf
*.sln    text eol=crlf
*.txt    text eol=crlf

# Binarios: Git no debe tocar finales de línea ni intentar hacer diff textual.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.7z     binary
*.exe    binary
*.dll    binary
